<main class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-8 border-b border-border pb-6">
        <h1 class="text-3xl font-semibold tracking-tight text-foreground"><%= __('category') %>: <%= page.category %></h1>
        <p class="mt-2 text-sm text-muted-foreground"><%= page.posts.length %> <%= __('posts') %></p>
    </header>

    <div class="flex flex-col gap-6">
        <% page.posts.sort('date').reverse().forEach(function(post) { %>
        <article class="border border-border rounded-lg p-6 transition-shadow hover:shadow-sm">
            <div class="flex items-baseline justify-between gap-4">
                <h2 class="text-xl font-medium leading-snug">
                    <a href="<%- url_for(post.path) %>" class="text-foreground hover:underline transition-colors"><%= post.title %></a>
                </h2>
                <time class="shrink-0 text-sm text-muted-foreground"><%= date(post.date, 'YYYY-MM-DD') %></time>
            </div>
            <p class="mt-2 text-muted-foreground leading-relaxed line-clamp-2">
                <% if (post.summary && post.summary.length > 0) { %><%- strip_html(post.summary).substring(0, 140) %><% } else { %><%- strip_html(post.content).substring(0, 140) %><% } %>
            </p>
            <% if (post.tags && post.tags.length) { %>
            <div class="mt-4 flex flex-wrap gap-2">
                <% post.tags.forEach(function(tag) { %>
                <a href="<%- url_for(tag.path) %>" class="text-xs text-muted-foreground hover:text-foreground transition-colors">#<%= tag.name %></a>
                <% }); %>
            </div>
            <% } %>
        </article>
        <% }); %>
    </div>

    <% if (page.total > 1) { %>
    <div class="mt-10">
        <%- partial('_partial/paging') %>
    </div>
    <% } %>
</main>
