<main class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-8 border-b border-border pb-6">
        <h1 class="text-3xl font-semibold tracking-tight text-foreground"><%= __('archives') %></h1>
        <p class="mt-2 text-sm text-muted-foreground"><%= __('posts') %></p>
    </header>

    <% if (theme.postCalendar) { %>
    <div class="mb-8">
        <%- partial('_widget/post-calendar') %>
    </div>
    <% } %>

    <%
    var year = '';
    page.posts.each(function(post) {
        var postYear = date(post.date, 'YYYY');
        if (postYear !== year) {
            if (year !== '') {
    %>
            </div></section>
    <%
            }
            year = postYear;
    %>
            <section class="mb-8">
                <h2 class="mb-4 text-2xl font-semibold tracking-tight text-foreground"><a href="<%- url_for('/archives/' + year) %>" class="hover:underline transition-colors"><%- year %></a></h2>
                <div class="flex flex-col gap-4">
    <%
        }
    %>
                    <article class="border border-border rounded-lg p-5 transition-shadow hover:shadow-sm">
                        <div class="flex items-baseline justify-between gap-4">
                            <h3 class="text-lg font-medium leading-snug">
                                <a href="<%- url_for(post.path) %>" class="text-foreground hover:underline transition-colors"><%= post.title %></a>
                            </h3>
                            <time class="shrink-0 text-sm text-muted-foreground"><%= date(post.date, 'YYYY-MM-DD') %></time>
                        </div>
                        <p class="mt-2 text-sm text-muted-foreground leading-relaxed line-clamp-2">
                            <% if (post.summary && post.summary.length > 0) { %><%- strip_html(post.summary).substring(0, 120) %><% } else { %><%- strip_html(post.content).substring(0, 120) %><% } %>
                        </p>
                        <% if (post.tags && post.tags.length) { %>
                        <div class="mt-3 flex flex-wrap gap-2">
                            <% post.tags.forEach(function(tag) { %>
                            <a href="<%- url_for(tag.path) %>" class="rounded-md bg-muted px-2 py-0.5 text-xs text-muted-foreground hover:bg-accent hover:text-foreground transition-colors">#<%= tag.name %></a>
                            <% }); %>
                        </div>
                        <% } %>
                    </article>
    <%
    });
    if (year !== '') {
    %>
                </div>
            </section>
    <%
    }
    %>

    <% if (page.total > 1) { %>
    <div class="mt-8">
        <%- partial('_partial/paging') %>
    </div>
    <% } %>
</main>
