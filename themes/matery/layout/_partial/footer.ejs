<footer class="border-t border-border bg-background">
  <div class="mx-auto max-w-5xl px-4 py-8 text-center text-sm text-muted-foreground">
    <p>
      Copyright &copy;
      <% if (theme.time && theme.time.enable && theme.time.year) { %><span id="year"><%- theme.time.year %><% if (theme.time.year != new Date().getFullYear()) { %>-<%- new Date().getFullYear() %><% } %></span><% } else { %><%- new Date().getFullYear() %><% } %>
      <a href="<%- url_for('/about') %>" class="hover:text-foreground transition-colors"><%- config.author %></a>
      &middot; Powered by <a href="https://hexo.io/" target="_blank" rel="noopener" class="hover:text-foreground transition-colors">Hexo</a>
    </p>
    <% if (theme.icp && theme.icp.enable) { %>
    <p class="mt-2">
      <a href="<%- theme.icp.url %>" target="_blank" rel="noopener" class="hover:text-foreground transition-colors"><%= theme.icp.text %></a>
    </p>
    <% } %>
  </div>
</footer>
