<div id="mobile-overlay" class="hidden fixed inset-0 z-40 bg-black/50 md:hidden"></div>
<aside id="mobile-drawer" class="hidden fixed right-0 top-0 z-50 h-full w-72 border-l border-border bg-background p-4 overscroll-contain md:hidden">
  <nav class="flex flex-col gap-1">
    <% Object.keys(theme.menu).forEach(function(key) { %>
      <% var item = theme.menu[key]; %>
      <% if (!item.children) { %>
      <a href="<%- url_for(item.url) %>" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted-foreground hover:bg-accent hover:text-foreground transition-colors">
        <% if (item.icon) { %><i class="<%- item.icon %>" aria-hidden="true" style="font-size:.85rem;width:1.25rem;"></i><% } %>
        <span><%- __(key) %></span>
      </a>
      <% } %>
    <% }); %>
    <div class="my-2 h-px bg-border"></div>
    <% if (theme.socialLink && theme.socialLink.github) { %>
    <a href="<%- theme.socialLink.github %>" target="_blank" rel="noopener" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-muted-foreground hover:bg-accent hover:text-foreground transition-colors">
      <i class="fab fa-github" aria-hidden="true" style="width:1.25rem;"></i><span>GitHub</span>
    </a>
    <% } %>
  </nav>
</aside>
