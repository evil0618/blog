<div class="row">
    <div class="col s10 offset-s1 m8 offset-m2 l8 offset-l2">
        <div class="brand">
            <div class="title center-align">
                <% if (config.subtitle && config.subtitle.length > 0) { %>
                <%= config.subtitle %>
                <% } else { %>
                    subtitle
                <% } %>
            </div>

            <div class="description center-align">
                <% if (theme.subtitle.enable) { %>
                <span id="subtitle"></span>
                <script src="<%- theme.jsDelivr.url %><%- url_for(theme.libs.js.typed) %>"></script>
                <script>
                    var typed = new Typed("#subtitle", {
                        strings: [ 
                            <% theme.subtitle.sub.forEach(function(item){%>
                                "<%= item %>",
                            <% }) %>
                        ],
                        startDelay: <%= theme.subtitle.startDelay %>,
                        typeSpeed: <%= theme.subtitle.typeSpeed %>,
                        loop: <%= theme.subtitle.loop %>,
                        backSpeed: <%= theme.subtitle.backSpeed %>,
                        showCursor: <%= theme.subtitle.showCursor %>
                    });
                </script>
                <% } else { %>
                    <%= config.description %>
                <% } %>
            </div>
        </div>
    </div>
</div>

<% if (theme.banner.enable) { %>
<script>
    // 使用必应每日壁纸作为背景
    var bingApiUrl = 'https://bing.biturl.top/?resolution=1920&format=image&index=0&mkt=zh-CN';
    function loadBingWallpaper() {
        var img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = function() {
            $('.bg-cover').css('background-image', 'url(' + bingApiUrl + ')');
            $('.bg-cover.about-cover').css('background-image', 'url(' + bingApiUrl + ')');
        };
        img.onerror = function() {
            // 必应壁纸加载失败时使用默认图片
            var fallbackUrl = "<%- theme.jsDelivr.url %><%- url_for('/medias/banner/0.jpg') %>";
            $('.bg-cover').css('background-image', 'url(' + fallbackUrl + ')');
            $('.bg-cover.about-cover').css('background-image', 'url(' + fallbackUrl + ')');
        };
        img.src = bingApiUrl;
    }
    loadBingWallpaper();
</script>
<% } else { %>
<script>
    $('.bg-cover').css('background-image', 'url(<%- theme.jsDelivr.url %><%- url_for('/medias/banner/0.jpg') %>)');
</script>
<% } %>
