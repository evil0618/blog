<nav class="mt-12 grid gap-4 sm:grid-cols-2" aria-label="文章导航">
  <% if (page.prev) { %>
  <a href="<%- url_for(page.prev.path) %>" class="group border border-border rounded-lg p-5 transition-shadow hover:shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
    <span class="inline-flex items-center gap-1 text-xs text-muted-foreground"><i class="fas fa-chevron-left" aria-hidden="true"></i> 上一篇</span>
    <span class="mt-1 block font-medium text-foreground group-hover:underline"><%= page.prev.title %></span>
  </a>
  <% } else { %>
  <span class="border border-border rounded-lg p-5 opacity-50">
    <span class="inline-flex items-center gap-1 text-xs text-muted-foreground"><i class="fas fa-chevron-left" aria-hidden="true"></i> 上一篇</span>
    <span class="mt-1 block text-muted-foreground">已是最早</span>
  </span>
  <% } %>
  <% if (page.next) { %>
  <a href="<%- url_for(page.next.path) %>" class="group border border-border rounded-lg p-5 text-right transition-shadow hover:shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
    <span class="inline-flex items-center gap-1 text-xs text-muted-foreground">下一篇 <i class="fas fa-chevron-right" aria-hidden="true"></i></span>
    <span class="mt-1 block font-medium text-foreground group-hover:underline"><%= page.next.title %></span>
  </a>
  <% } else { %>
  <span class="border border-border rounded-lg p-5 text-right opacity-50">
    <span class="inline-flex items-center gap-1 text-xs text-muted-foreground">下一篇 <i class="fas fa-chevron-right" aria-hidden="true"></i></span>
    <span class="mt-1 block text-muted-foreground">已是最新</span>
  </span>
  <% } %>
</nav>
