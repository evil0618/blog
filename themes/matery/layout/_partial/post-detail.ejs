<!-- 文章内容详情 -->
<div class="mx-auto max-w-3xl px-4 py-12">
  <header class="mb-8 border-b border-border pb-6">
    <h1 class="text-3xl font-semibold tracking-tight text-foreground"><%= page.title %></h1>
    <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-muted-foreground">
      <% if (theme.postInfo && theme.postInfo.date) { %>
      <span class="inline-flex items-center gap-1"><i class="far fa-calendar" aria-hidden="true"></i><%= date(page.date, 'YYYY-MM-DD') %></span>
      <% } %>
      <% if (theme.postInfo && theme.postInfo.min2read && typeof min2read === 'function') { %>
      <span class="inline-flex items-center gap-1"><i class="far fa-clock" aria-hidden="true"></i><%= min2read(page.content) %> 分钟</span>
      <% } %>
      <% if (page.categories && page.categories.length) { %>
      <span class="inline-flex items-center gap-1"><i class="fas fa-bookmark" aria-hidden="true"></i>
        <% page.categories.forEach(function(c, i){ %><a href="<%- url_for(c.path) %>" class="hover:text-foreground transition-colors"><%= c.name %></a><% if (i < page.categories.length-1){ %> / <% } %><% }); %>
      </span>
      <% } %>
    </div>
  </header>

  <div class="post-content">
    <%- page.content %>
  </div>

  <%- partial('_partial/reprint-statement') %>

  <% if (page.tags && page.tags.length) { %>
  <div class="mt-8 flex flex-wrap gap-2">
    <% page.tags.forEach(function(tag){ %>
    <a href="<%- url_for(tag.path) %>" class="inline-flex items-center rounded-md border border-border bg-background px-2.5 py-1 text-xs text-muted-foreground hover:bg-accent hover:text-foreground transition-colors">#<%= tag.name %></a>
    <% }); %>
  </div>
  <% } %>

  <% if (theme.reward && theme.reward.enable) { %><%- partial('_partial/reward') %><% } %>

  <% if (theme.gitalk && theme.gitalk.enable) { %><%- partial('_partial/gitalk') %><% } %>
  <% if (theme.gitment && theme.gitment.enable) { %><%- partial('_partial/gitment') %><% } %>
  <% if (theme.disqus && theme.disqus.enable) { %><%- partial('_partial/disqus') %><% } %>
  <% if (theme.livere && theme.livere.enable) { %><%- partial('_partial/livere') %><% } %>
  <% if (theme.valine && theme.valine.enable) { %><%- partial('_partial/valine') %><% } %>
  <% if (theme.waline && theme.waline.enable) { %><%- partial('_partial/waline') %><% } %>
  <% if (theme.changyan && theme.changyan.enable) { %><%- partial('_partial/changyan') %><% } %>
  <% if (theme.twikoo && theme.twikoo.enable) { %><%- partial('_partial/twikoo') %><% } %>

  <%- partial('_partial/prev-next') %>
</div>

<%- partial('_partial/codeblock') %>
