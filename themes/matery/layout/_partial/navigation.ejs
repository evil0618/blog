<nav class="hidden md:flex items-center gap-1">
  <% Object.keys(theme.menu).forEach(function(key) { %>
    <% var item = theme.menu[key]; %>
    <% if (!item.children) { %>
      <% var active = false;
         if (item.url === '/' ) active = is_home();
         else if (item.url.indexOf('/tags') === 0) active = is_tag();
         else if (item.url.indexOf('/categories') === 0) active = is_category();
         else if (item.url.indexOf('/about') === 0) active = (page.title === 'about' || page.canonical_path && page.canonical_path.indexOf('/about') === 0);
      %>
      <a href="<%- url_for(item.url) %>" class="inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-sm font-medium <%= active ? 'bg-accent text-foreground' : 'text-muted-foreground hover:bg-accent hover:text-foreground' %> transition-colors">
        <% if (item.icon) { %><i class="<%- item.icon %>" aria-hidden="true" style="font-size:.75rem;"></i><% } %>
        <span><%- __(key) %></span>
      </a>
    <% } %>
  <% }); %>
</nav>
