<main class="mx-auto max-w-3xl px-4 py-12">
  <header class="mb-10 text-center">
    <h1 class="text-3xl font-semibold tracking-tight text-foreground"><%= config.title %></h1>
    <% if (config.description && config.description.length) { %>
    <p class="mt-2 text-muted-foreground"><%= config.description %></p>
    <% } %>
  </header>

  <div class="flex flex-col gap-6">
    <% page.posts.forEach(function(post) { %>
      <% if (post.hide !== true) { %>
      <article class="border border-border rounded-lg p-6 transition-shadow hover:shadow-sm">
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="text-xl font-medium leading-snug">
            <a href="<%- url_for(post.path) %>" class="text-foreground hover:text-foreground hover:underline transition-colors"><%= post.title %></a>
          </h2>
          <time class="shrink-0 text-sm text-muted-foreground"><%= date(post.date, 'YYYY-MM-DD') %></time>
        </div>
        <p class="mt-2 text-muted-foreground leading-relaxed line-clamp-2">
          <% if (post.summary && post.summary.length) { %><%- strip_html(post.summary).substring(0, 140) %><% } else if (post.excerpt && post.excerpt.length) { %><%- strip_html(post.excerpt).substring(0, 140) %><% } else if (post.content && post.content.length) { %><%- strip_html(post.content).substring(0, 140) %><% } %>
        </p>
        <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
          <div class="flex flex-wrap gap-x-3 gap-y-1">
            <% if (post.tags && post.tags.length) { %>
              <% post.tags.forEach(function(tag) { %>
              <a href="<%- url_for(tag.path) %>" class="text-xs text-muted-foreground hover:text-foreground transition-colors">#<%= tag.name %></a>
              <% }); %>
            <% } %>
          </div>
          <span class="text-xs text-muted-foreground">
            <% if (post.categories && post.categories.length) { var _c = post.categories.first(); %><%= _c ? _c.name : '' %><% } %>
          </span>
        </div>
      </article>
      <% } %>
    <% }); %>
  </div>

  <% if (page.total > 1) { %>
  <div class="mt-10">
    <%- partial('_partial/paging') %>
  </div>
  <% } %>
</main>
