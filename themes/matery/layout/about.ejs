<main class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-8 border-b border-border pb-6 text-center">
        <img src="<%- url_for(theme.profile.avatar) %>" alt="<%- config.author %>" class="mx-auto h-24 w-24 rounded-full border border-border" width="96" height="96">
        <h1 class="mt-4 text-3xl font-semibold tracking-tight text-foreground"><%- config.author %></h1>
        <% if (theme.profile.career) { %><p class="mt-1 text-sm text-muted-foreground"><%- theme.profile.career %></p><% } %>
        <% if (theme.profile.introduction) { %><p class="mt-4 text-foreground"><%- theme.profile.introduction %></p><% } %>
    </header>
    <% if (theme.myProjects && theme.myProjects.enable) { %><%- partial('_widget/my-projects') %><% } %>
    <% if (theme.mySkills && theme.mySkills.enable) { %><%- partial('_widget/my-skills') %><% } %>
    <% if (theme.myGallery && theme.myGallery.enable) { %><%- partial('_widget/my-gallery') %><% } %>
    <% if (page.content && page.content.length > 0) { %><div class="post-content mt-8"><%- page.content %></div><% } %>
</main>
