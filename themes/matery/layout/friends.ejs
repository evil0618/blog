<main class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-8 border-b border-border pb-6">
        <h1 class="text-3xl font-semibold tracking-tight text-foreground"><i class="fas fa-address-book mr-2" aria-hidden="true"></i><%= __('friends') %></h1>
    </header>
    <% if (site.data && site.data.friends) { %>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% site.data.friends.forEach(function(friend, i){ %>
        <a href="<%- url_for(friend.url) %>" target="_blank" rel="noopener" class="block border border-border rounded-lg p-5 hover:shadow-sm transition-shadow">
            <div class="flex items-center gap-3">
                <img src="<%- url_for(friend.avatar) %>" alt="<%= friend.name %>" class="h-12 w-12 rounded-full border border-border" width="48" height="48" loading="lazy">
                <div>
                    <div class="font-medium text-foreground"><%= friend.name %></div>
                    <% if (friend.introduction) { %><div class="text-xs text-muted-foreground line-clamp-2"><%= friend.introduction %></div><% } %>
                </div>
            </div>
            <% if (friend.title) { %><div class="mt-3 text-xs text-muted-foreground"><%= friend.title %></div><% } %>
        </a>
        <% }); %>
    </div>
    <% } %>
    <% if (page.content && page.content.length > 0) { %><div class="post-content mt-8"><%- page.content %></div><% } %>
</main>
