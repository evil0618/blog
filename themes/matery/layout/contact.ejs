<main class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-8 border-b border-border pb-6">
        <h1 class="text-3xl font-semibold tracking-tight text-foreground"><i class="fas fa-comments mr-2" aria-hidden="true"></i><%= __('contact') %></h1>
    </header>
    <% if (page.content && page.content.length > 0) { %>
    <div class="post-content"><%- page.content %></div>
    <% } %>

    <% if (theme.gitalk && theme.gitalk.enable) { %><%- partial('_partial/gitalk') %><% } %>
    <% if (theme.gitment && theme.gitment.enable) { %><%- partial('_partial/gitment') %><% } %>
    <% if (theme.disqus && theme.disqus.enable) { %><%- partial('_partial/disqus') %><% } %>
    <% if (theme.livere && theme.livere.enable) { %><%- partial('_partial/livere') %><% } %>
    <% if (theme.valine && theme.valine.enable) { %><%- partial('_partial/valine') %><% } %>
    <% if (theme.waline && theme.waline.enable) { %><%- partial('_partial/waline') %><% } %>
    <% if (theme.changyan && theme.changyan.enable) { %><%- partial('_partial/changyan') %><% } %>
    <% if (theme.twikoo && theme.twikoo.enable) { %><%- partial('_partial/twikoo') %><% } %>
</main>
